# Booking uses only Resend (no database required). You get each booking by email.
# Optional: Database for newsletter signups and auth. Leave empty if you only need booking emails.
DATABASE_URL=

# Resend – booking confirmations (client + copy to you)
# API key: https://resend.com/api-keys
# Verify your sending domain in Resend (e.g. spinella.ch). Emails send from reservations@<that domain>.
RESEND_API_KEY=re_your_api_key_here
# Email where you receive a copy of each booking (e.g. info@spinella.ch)
RESTAURANT_EMAIL=info@spinella.ch

# When the site is on Vercel and the API is at spinella.ch, set this in Vercel’s build env:
# VITE_API_URL=https://www.spinella.ch
# (Use https://spinella.ch if API is on root domain.) Set CORS_ORIGIN on the API to your Vercel/site URL.

# Supabase (for bookings + admin + clients + newsletter). Get from Supabase → Project Settings → API.
# Newsletter: run docs/supabase-newsletter-table.sql in Supabase SQL Editor. Unsubscribe: /api/newsletter-unsubscribe?token=...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# VAPID keys for Web Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Wix Table Reservations – sync into admin (Admin → Sync from Wix)
# Get Site ID and API key from Wix Developer Center; grant Table Reservations / Manage Reservations.
# In Vercel: Project → Settings → Environment Variables. Add for Production (and Preview if you want).
WIX_SITE_ID=
WIX_API_KEY=
# Optional: auth, CORS, port
JWT_SECRET=your-secret-key-here
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
CORS_ORIGIN=
PORT=3000
NODE_ENV=development
